NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://shopfront:shopfront@localhost:5432/shopfront?schema=public
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=your_gemini_api_key
SENTRY_DSN=https://examplePublicKey.ingest.sentry.io/0
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890
BASE_URL=https://shopfront-production-2dc5.up.railway.app
SITE_OUTPUT_DIR=public/sites
SKIP_TWILIO_VALIDATION=false
SKIP_TWILIO_SEND=false
MOCK_LLM=false
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret
TELEGRAM_BOT_USERNAME=your_bot_username
SKIP_TELEGRAM_VALIDATION=false
# Legacy compatibility (tests/older envs)
MOCK_ANTHROPIC=false
